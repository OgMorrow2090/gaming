<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.itinyk.gw2-mystic-clicker-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-l</string>
        <string>/Users/shaunchittenden/Developer/GitHub/ogmorrow2090/guildwars2/scripts/watch-mystic-clicker.sh</string>
    </array>

    <!-- Run every 5 minutes. -->
    <key>StartInterval</key>
    <integer>300</integer>

    <!-- Also run once at agent load so we don't wait 5 min on first install. -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/gw2-mystic-clicker-watcher.out</string>

    <key>StandardErrorPath</key>
    <string>/tmp/gw2-mystic-clicker-watcher.err</string>

    <!-- Inherit user's normal PATH so gh, ssh, git resolve correctly. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
