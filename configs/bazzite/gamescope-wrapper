#!/bin/bash
# gamescope-wrapper: reads ~/.config/gamescope-mode and sets matching
# gamescope output + resolution flags. Called in place of /usr/bin/gamescope
# by the bazzite session.

MODE_FILE="$HOME/.config/gamescope-mode"
MODE="default"
[ -f "$MODE_FILE" ] && MODE=$(cat "$MODE_FILE" 2>/dev/null | tr -d "[:space:]")

case "$MODE" in
  4k165)     exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 3840 -H 2160 -r 165 -o 165 --adaptive-sync ;;
  4k144)     exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 3840 -H 2160 -r 144 -o 144 --adaptive-sync ;;
  4k120)     exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 3840 -H 2160 -r 120 -o 120 --adaptive-sync ;;
  4k60)      exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 3840 -H 2160 -r 60  -o 60  --adaptive-sync ;;
  2k165)     exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 2560 -H 1440 -r 165 -o 165 --adaptive-sync ;;
  2k120)     exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 2560 -H 1440 -r 120 -o 120 --adaptive-sync ;;
  1080p165)  exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 1920 -H 1080 -r 165 -o 165 --adaptive-sync ;;
  1080p144)  exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 1920 -H 1080 -r 144 -o 144 --adaptive-sync ;;
  deck)      exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 1280 -H 800  -r 90  -o 90  --adaptive-sync ;;
  default|*) exec /usr/bin/gamescope "$@" --prefer-output DP-2 -W 3840 -H 2160 -r 165 -o 165 --adaptive-sync ;;
esac
